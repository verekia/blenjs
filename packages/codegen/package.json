{
  "name": "@blenjs/codegen",
  "version": "0.0.0",
  "description": "BlenJS codegen: registry -> components.schema.json. Node-only. Owns the schema-contract format.",
  "type": "module",
  "main": "src/index.ts",
  "module": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@blenjs/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "25.7.0",
    "typescript": "6.0.3",
    "zod": "4.4.3"
  },
  "peerDependencies": {
    "zod": "^4"
  }
}
